{
  "name": "@cendaro/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "AGPL-3.0",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --cache --cache-location .cache/.eslintcache",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run"
  },
  "dependencies": {
    "@cendaro/db": "workspace:*",
    "@cendaro/validators": "workspace:*",
    "@supabase/supabase-js": "^2.100.1",
    "@trpc/server": "catalog:",
    "drizzle-orm": "catalog:",
    "superjson": "2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cendaro/eslint-config": "workspace:*",
    "@cendaro/prettier-config": "workspace:*",
    "@cendaro/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "prettier": "@cendaro/prettier-config",
  "author": "Cendaro",
  "repository": {
    "type": "git",
    "url": "https://github.com/cendaro/cendaro.git"
  },
  "bugs": {
    "url": "https://github.com/cendaro/cendaro/issues"
  }
}
