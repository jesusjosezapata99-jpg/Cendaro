# ┌──────────────────────────────────────────────────────────────┐
# │  CENDARO — Environment Configuration                       │
# │                                                            │
# │  ⚠  SECURITY: Before making this repository public,       │
# │  you MUST rotate ALL secrets in their respective            │
# │  dashboards to prevent credential exposure:                 │
# │                                                            │
# │  1. Supabase → Settings → Database → Regenerate Password   │
# │  2. Supabase → Settings → API → Regenerate JWT Secret      │
# │  3. Supabase → Settings → API → Regenerate Service Key     │
# │  4. Groq Console → API Keys → Rotate                       │
# │  5. Stripe Dashboard → Developers → Roll API Keys          │
# │  6. Mercado Libre → App Settings → Regenerate Secret       │
# │                                                            │
# │  NEVER commit real values to version control.               │
# └──────────────────────────────────────────────────────────────┘

# Supabase
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry (optional for dev)
SENTRY_DSN=

# Mercado Libre (Phase 5)
MERCADOLIBRE_APP_ID=
MERCADOLIBRE_SECRET=
MERCADOLIBRE_REDIRECT_URI=

# AI & Processing
GROQ_API_KEY=
LTX_API_KEY=

# Services
EXCHANGE_RATE_API_KEY=

# App
PORT=3000
NODE_ENV=development
